# ANet environment variables — copy this file to `.env` and fill in only what you need.
#
#   cp .env.example .env        (Windows: copy .env.example .env)
#
# ANet loads `.env` from the directory you run it in (and your shell env). You do
# NOT need all of these — set the key(s) for the provider(s) you actually use.
# Everything here is optional except an API key for at least one provider.
# ─────────────────────────────────────────────────────────────────────────────


# ── Model providers — set at least ONE ──────────────────────────────────────
# The cheapest way to start: an OpenRouter key (300+ models, free tier available).

OPENROUTER_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# ── Vertex AI (optional) — for provider: vertex_google / vertex_anthropic ────
# Also run once:  gcloud auth application-default login
VERTEX_PROJECT_ID=
VERTEX_LOCATION=          # default: us-central1


# ── ANet settings (optional) ─────────────────────────────────────────────────
# ANET_HOME      — where ANet stores your data (config, packs, sessions). Default: ~/.anet
# ASSISTANT_NAME — rename the assistant (shown in the banner/prompts). Default: Anet
ANET_HOME=
ASSISTANT_NAME=


# ── Pack / tool secrets ───────────────────────────────────────────────────────
# These do NOT go here. A pack's tools/agents keep their own secrets in a
# per-agent file:  <anet-home>/anet_pack/ExAgents/<agent>/.env  (auto-loaded at
# startup). E.g. the default pack's Telegram agent reads TELEGRAM_BOT_TOKEN /
# TELEGRAM_CHAT_ID from  anet_pack/ExAgents/tele_agent/.env  — see its .env.example.
