# ── Secrets & config ──────────────────────────────────────────────────────────
.env
*.env
# A user's personal root config (legacy / local dev override). Anchored to the
# repo root so it does NOT match the shipped default at anet_pack/anet.config.yaml.
/anet.config.yaml

# ── Session memory ────────────────────────────────────────────────────────────
# Legacy in-repo session store. Sessions now live in ~/.anet (or your ANET_HOME).
# Anchored to the repo root (leading slash) so it ONLY matches a top-level memory/
# folder — NOT anet/memory/ (the vendored RecMem package, which MUST be tracked).
/memory/

# ── Agent sandbox ─────────────────────────────────────────────────────────────
# Runtime working dir: downloads and bare-filename writes land here.
anet_files/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
*.egg-info/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Node / frontend ───────────────────────────────────────────────────────────
node_modules/
anet-ui/dist/
.next/
.nuxt/
*.tsbuildinfo

# ── Project code graphs ───────────────────────────────────────────────────────
# graph.json built locally — never commit
.anet/

# ── Plugin secrets ────────────────────────────────────────────────────────────
# each plugin has its own .env with credentials
plugins/*/.env

# ── Downloads / generated files ───────────────────────────────────────────────
anet/agents/3dAgent/tasks/downloads/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo


#  Mcp
.mcps/codegraph/codegraph

# MCP server data dirs. Playwright's output now lands under the Anet home
# (<home>/mcp/playwright/); codegraph's graph is project-local by design (it walks
# parent dirs to find it, like .git), so it stays in the repo — ignore it here.
.code-review-graph/
.codegraph/
.playwright-mcp/

# ── anet_pack (the dev workspace) — keep source defaults, ignore heavy/runtime bits ──
# The vendored codegraph MCP must never be committed or shipped (huge,
# machine-specific, carries its own .git + node_modules). Users install MCP
# servers themselves via /addmcp. (node_modules/ and .env/*.env are already
# ignored globally above — secrets never ship.)
anet_pack/mcps/codegraph/
# Runtime artifacts created while developing against anet_pack/.
anet_pack/skills/.usage.json
anet_pack/skills/archived/